{
    "version": 2,
    "functions": {
        "src/server.js": {
            "runtime": "vercel-node@latest",
            "memory": 1024,
            "maxDuration": 15
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/src/server.js"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    }
}
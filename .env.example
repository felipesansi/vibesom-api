# Servidor
PORT=3333

# IA — Gemini (prioridade na busca e no fallback de stream)
# Chave (formato AIza...): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Um modelo ou vários separados por vírgula (tenta na ordem se der 429)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite

# IA — OpenAI (opcional; usado só se GEMINI_API_KEY não estiver definida)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
